# Swift build output (matches at any depth, e.g. apps/desktop/.build)
.build/
build/
.swiftpm/

# Nightly/Dev app icons — generated locally on first build, not shipped.
# (The stable AppIcon.icns IS committed so CI doesn't need to re-render it.)
apps/desktop/Resources/AppIcon-Nightly.icns
apps/desktop/Resources/AppIcon-Dev.icns

# The whisper speech model (148 MB) — downloaded by setup.sh, never committed.
apps/desktop/Resources/engine/models/

# Vendored engine binaries (ffmpeg/ffprobe/whisper-cli/python) — fetched & built
# by Scripts/vendor.sh at build time, never committed.
apps/desktop/.vendor/

# Python bytecode
__pycache__/
*.pyc

# Polar licensing account identifiers — injected into Info.plist at build time by
# dev.sh/nightly.sh/build.sh. Real values stay out of the repo (copy .polar.env.example
# to .polar.env; release builds inject from GitHub Actions secrets).
.polar.env

# Node / Turborepo / Vite (apps/web). Package manager: bun (bun.lock is committed).
node_modules/
dist/
.turbo/
*.local
.vite/

.DS_Store

# TypeScript incremental build info
*.tsbuildinfo
