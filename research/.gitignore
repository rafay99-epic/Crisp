data/ml-stuttering-events-dataset/wavs/
data/ml-stuttering-events-dataset/clips/
data/ml-stuttering-events-dataset/.venv-sep/
*.mlmodel

# Trained weights + Core ML exports — regenerated by training, not versioned.
checkpoints/
*.pt
*.mlpackage

# Stray large media that might land outside data/ by accident.
*.wav
*.zip

# validate-tool scratch (your hand labels for a window)
labels.json
