# Polar licensing account identifiers for Crisp.
#
# Copy this file to `.polar.env` (gitignored) and fill in your values. dev.sh and
# nightly.sh load it and `build.sh` injects the values into the app's Info.plist
# (read at runtime by PolarConfig). Leaving any value blank disables that piece.
#
# For RELEASE builds (ci.yml), set these as GitHub Actions secrets and pass them to
# build.sh as the same env vars — don't put real values in this committed example.
#
# None of these are secrets (the Polar API token lives only in the serverless
# function, never here) — this just keeps account-specific values out of the repo.

CRISP_POLAR_ORG_ID=
CRISP_POLAR_CHECKOUT_URL=
CRISP_POLAR_PORTAL_URL=
CRISP_POLAR_LOOKUP_URL=
