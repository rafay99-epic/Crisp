<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ══════════════════════════════════════════════════════════════════════
         Crisp for Windows — design tokens.

         Values mirror the WinUI 3 / Windows 11 Fluent palette so the app reads
         as a native Windows app rather than a ported macOS one. Everything is
         keyed by theme variant (Dark/Light) and consumed through the Crisp*
         aliases, so a view never hardcodes a colour again.

         The window itself is Mica; the navigation pane sits directly on it
         (like Media Player / Store / Settings) and the page content lives on a
         "layer" surface (CrispLayer) with a rounded top-left corner — the
         signature Windows 11 NavigationView look. Cards then stack on that
         layer with the WinUI card fill.
         ══════════════════════════════════════════════════════════════════════ -->

    <ResourceDictionary.ThemeDictionaries>
        <!-- ───────────────────────── Dark ───────────────────────── -->
        <ResourceDictionary x:Key="Dark">
            <!-- Opaque base — window fallback when Mica is unavailable, and the
                 first-run onboarding cover. WinUI SolidBackgroundFillColorBase. -->
            <SolidColorBrush x:Key="CrispWindowBg"     Color="#202020"/>
            <!-- Content layer the pages sit on (WinUI LayerFillColorDefault):
                 slightly lighter than the Mica base, translucent so the
                 backdrop tints through. -->
            <SolidColorBrush x:Key="CrispLayer"        Color="#3A3A3A" Opacity="0.30"/>
            <!-- Card surface on the layer (WinUI CardBackgroundFillColorDefault). -->
            <SolidColorBrush x:Key="CrispCard"         Color="#FFFFFF" Opacity="0.05"/>
            <!-- Hairline card/divider stroke (WinUI CardStrokeColorDefault). -->
            <SolidColorBrush x:Key="CrispCardBorder"   Color="#FFFFFF" Opacity="0.08"/>
            <!-- Inset / secondary layer inside a card (WinUI ControlFillColorDefault). -->
            <SolidColorBrush x:Key="CrispInset"        Color="#FFFFFF" Opacity="0.05"/>
            <!-- Hover / selected fills for list & nav items (WinUI SubtleFillColor). -->
            <SolidColorBrush x:Key="CrispSubtleFill"        Color="#FFFFFF" Opacity="0.06"/>
            <SolidColorBrush x:Key="CrispSubtleFillStrong"  Color="#FFFFFF" Opacity="0.04"/>
            <!-- Row divider inside a settings group. -->
            <SolidColorBrush x:Key="CrispDivider"      Color="#FFFFFF" Opacity="0.07"/>
            <!-- Text ramp (WinUI TextFillColor Primary/Secondary/Tertiary). -->
            <SolidColorBrush x:Key="CrispText"         Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CrispSecondary"    Color="#FFFFFF" Opacity="0.77"/>
            <SolidColorBrush x:Key="CrispTertiary"     Color="#FFFFFF" Opacity="0.55"/>
            <!-- Status colours (WinUI System success / critical, dark). -->
            <SolidColorBrush x:Key="CrispSuccess"      Color="#6CCB5F"/>
            <SolidColorBrush x:Key="CrispDanger"       Color="#FF99A4"/>
            <!-- InfoBar-style banner fill (WinUI CardBackgroundFillColorSecondary). -->
            <SolidColorBrush x:Key="CrispBannerBg"     Color="#FFFFFF" Opacity="0.03"/>
        </ResourceDictionary>

        <!-- ───────────────────────── Light ───────────────────────── -->
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="CrispWindowBg"     Color="#F3F3F3"/>
            <SolidColorBrush x:Key="CrispLayer"        Color="#FFFFFF" Opacity="0.50"/>
            <SolidColorBrush x:Key="CrispCard"         Color="#FFFFFF" Opacity="0.70"/>
            <SolidColorBrush x:Key="CrispCardBorder"   Color="#000000" Opacity="0.06"/>
            <SolidColorBrush x:Key="CrispInset"        Color="#000000" Opacity="0.03"/>
            <SolidColorBrush x:Key="CrispSubtleFill"        Color="#000000" Opacity="0.04"/>
            <SolidColorBrush x:Key="CrispSubtleFillStrong"  Color="#000000" Opacity="0.02"/>
            <SolidColorBrush x:Key="CrispDivider"      Color="#000000" Opacity="0.06"/>
            <SolidColorBrush x:Key="CrispText"         Color="#000000" Opacity="0.89"/>
            <SolidColorBrush x:Key="CrispSecondary"    Color="#000000" Opacity="0.62"/>
            <SolidColorBrush x:Key="CrispTertiary"     Color="#000000" Opacity="0.45"/>
            <SolidColorBrush x:Key="CrispSuccess"      Color="#0F7B0F"/>
            <SolidColorBrush x:Key="CrispDanger"       Color="#C42B1C"/>
            <SolidColorBrush x:Key="CrispBannerBg"     Color="#FFFFFF" Opacity="0.55"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- Accent: a brush off the OS accent Color (SystemAccentColor is a Color). -->
    <SolidColorBrush x:Key="CrispAccent" Color="{DynamicResource SystemAccentColor}"/>

    <!-- Shape: Windows 11 uses 8px on cards/dialogs, 4px on small controls. -->
    <CornerRadius x:Key="CrispCardRadius">8</CornerRadius>
    <CornerRadius x:Key="CrispControlRadius">4</CornerRadius>
    <!-- The content pane's rounded top-left corner (NavigationView layer). -->
    <CornerRadius x:Key="CrispPaneRadius">8,0,0,0</CornerRadius>

    <!-- Layout: the navigation pane's fixed (expanded) width. -->
    <x:Double x:Key="CrispNavWidth">208</x:Double>

    <!-- Fonts: the actual Windows 11 system font families. -->
    <FontFamily x:Key="CrispFont">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="CrispFontDisplay">Segoe UI Variable Display, Segoe UI</FontFamily>
    <FontFamily x:Key="CrispIconFont">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>
</ResourceDictionary>
