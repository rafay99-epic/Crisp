<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Crisp.ViewModels"
        xmlns:models="using:Crisp.Models"
        xmlns:controls="using:Crisp.Views.Controls"
        xmlns:crisp="using:Crisp"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="600"
        x:Class="Crisp.Views.ReviewWindow"
        x:DataType="vm:ReviewModel"
        Width="560" Height="600" MinWidth="440" MinHeight="420"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Title="Review cuts">

    <DockPanel>
        <!-- Reserve the native (Mica) caption strip so content clears it. -->
        <Panel DockPanel.Dock="Top" Height="{x:Static crisp:WindowChrome.TitleBarHeight}"/>

        <StackPanel DockPanel.Dock="Top" Spacing="3" Margin="24,2,24,0">
            <TextBlock Text="{Binding FileName}" Classes="subtitle" TextTrimming="CharacterEllipsis"/>
            <TextBlock Text="{Binding Status}" Classes="caption"/>
        </StackPanel>

        <Border DockPanel.Dock="Top" Classes="card" Margin="24,12" Height="84" Padding="8">
            <Panel>
                <controls:WaveformView Preview="{Binding Preview}"/>
                <TextBlock Text="Analyzing…" Classes="secondary" HorizontalAlignment="Center"
                           VerticalAlignment="Center" IsVisible="{Binding IsAnalyzing}"/>
            </Panel>
        </Border>

        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto,Auto" Margin="24,12,24,20">
            <TextBlock Grid.Column="0" Classes="caption" VerticalAlignment="Center" TextWrapping="Wrap"
                       Text="Uncheck a pause to keep it. Apply renders exactly the checked cuts — no re-detection."/>
            <Button Grid.Column="1" Content="Cancel" Click="OnCancel" Margin="10,0,8,0"/>
            <Button Grid.Column="2" Content="Apply &amp; Clean" Click="OnApply" Classes="accent" IsEnabled="{Binding CanApply}"/>
        </Grid>

        <ScrollViewer Margin="24,0,24,0">
            <ItemsControl ItemsSource="{Binding Regions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:CutRegion">
                        <CheckBox IsChecked="{Binding Remove}" Margin="0,2"
                                  AutomationProperties.Name="Remove this pause">
                            <TextBlock Text="{Binding TimeLabel}" VerticalAlignment="Center"/>
                        </CheckBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
