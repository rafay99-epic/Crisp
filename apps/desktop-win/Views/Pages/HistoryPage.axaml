<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="using:Crisp.Services"
             xmlns:models="using:Crisp.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="780" d:DesignHeight="620"
             x:Class="Crisp.Views.Pages.HistoryPage"
             x:DataType="svc:HistoryStore">

    <UserControl.Styles>
        <Style Selector="Border.historyRow">
            <Setter Property="CornerRadius" Value="{DynamicResource CrispControlRadius}"/>
            <Setter Property="Background" Value="{DynamicResource CrispCard}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CrispCardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </UserControl.Styles>

    <DockPanel LastChildFill="True" Margin="24,20,24,20">

        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,18">
            <TextBlock Grid.Column="0" Text="History" Classes="pageTitle"/>
            <Button Grid.Column="1" Content="Clear History" Click="OnClear"
                    IsEnabled="{Binding !IsEmpty}" VerticalAlignment="Center"/>
        </Grid>

        <Panel>
            <!-- empty state -->
            <StackPanel IsVisible="{Binding IsEmpty}" Spacing="10"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Classes="icon tertiary" Text="&#xE81C;" FontSize="32"/>
                <TextBlock Classes="secondary" Text="No cleans yet." HorizontalAlignment="Center"/>
                <TextBlock Classes="tertiary" FontSize="12" HorizontalAlignment="Center"
                           Text="Every video you clean shows up here."/>
            </StackPanel>

            <ScrollViewer IsVisible="{Binding !IsEmpty}">
                <ItemsControl ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:HistoryEntry">
                            <Border Classes="historyRow">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding InputName}" Classes="bodyStrong" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Classes="caption" Text="{Binding DateText}"/>
                                        <TextBlock Classes="caption" IsVisible="{Binding CutsText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                   Text="{Binding CutsText}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Classes="caption success" VerticalAlignment="Center"
                                                   Text="{Binding SavedText, StringFormat='saved {0}'}"/>
                                        <Button Content="Reveal" Click="OnReveal" CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Panel>
    </DockPanel>
</UserControl>
