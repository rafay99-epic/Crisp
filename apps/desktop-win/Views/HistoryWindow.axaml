<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="using:Crisp.Services"
        xmlns:models="using:Crisp.Models"
        xmlns:controls="using:Crisp.Views.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="560"
        x:Class="Crisp.Views.HistoryWindow"
        x:DataType="svc:HistoryStore"
        Width="520" Height="560" MinWidth="420" MinHeight="360"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Title="Crisp History">

    <DockPanel LastChildFill="True">
        <!-- Reserve the native (Mica) caption strip so content clears it. -->
        <Panel DockPanel.Dock="Top" Height="34"/>

        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto" Margin="24,2,24,14">
            <controls:WaveformMark Grid.Column="0" Height="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Grid.Column="1" Text="History" Classes="subtitle" VerticalAlignment="Center"/>
            <Button Grid.Column="2" Content="Clear" Click="OnClear" IsEnabled="{Binding !IsEmpty}"/>
        </Grid>

        <Panel Margin="24,0,24,20">
            <TextBlock IsVisible="{Binding IsEmpty}" Classes="secondary" VerticalAlignment="Center"
                       HorizontalAlignment="Center" Text="No cleans yet."/>

            <Border Classes="card" Padding="6" IsVisible="{Binding !IsEmpty}">
                <ListBox ItemsSource="{Binding Entries}" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:HistoryEntry">
                            <Grid ColumnDefinitions="*,Auto" Margin="4,6">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{Binding InputName}" Classes="bodyStrong" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Classes="caption" Text="{Binding DateText}"/>
                                    <TextBlock Classes="caption" IsVisible="{Binding CutsText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               Text="{Binding CutsText}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Classes="caption" VerticalAlignment="Center"
                                               Text="{Binding SavedText, StringFormat='saved {0}'}"/>
                                    <Button Content="Reveal" Click="OnReveal" CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Panel>
    </DockPanel>
</Window>
