<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="using:Crisp.Services"
        xmlns:models="using:Crisp.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="460" d:DesignHeight="640"
        x:Class="Crisp.Views.SettingsWindow"
        x:DataType="svc:EngineSettings"
        Width="460" Height="660"
        Background="{DynamicResource CrispWindowBg}"
        WindowStartupLocation="CenterOwner"
        Title="Crisp Settings">

    <Window.Styles>
        <Style Selector="TextBlock.head">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style Selector="TextBlock.lbl">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource CrispSecondary}"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="MinWidth" Value="140"/>
        </Style>
    </Window.Styles>

    <ScrollViewer>
        <StackPanel Margin="22" Spacing="14">

            <TextBlock Text="Settings" FontSize="22" FontWeight="Bold"/>

            <!-- Encoding -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="head" Text="Encoding"/>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Video codec"/>
                        <ComboBox Grid.Column="1" AutomationProperties.Name="Video codec" ItemsSource="{Binding VideoCodecs}" SelectedItem="{Binding VideoCodec}"/></Grid>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Hardware acceleration"/>
                        <ToggleSwitch Grid.Column="1" AutomationProperties.Name="Hardware acceleration" HorizontalAlignment="Right" IsChecked="{Binding HardwareEncoding}"/></Grid>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Quality"/>
                        <ComboBox Grid.Column="1" AutomationProperties.Name="Quality" ItemsSource="{Binding Qualities}" SelectedItem="{Binding VideoQuality}"/></Grid>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Container"/>
                        <ComboBox Grid.Column="1" AutomationProperties.Name="Container" ItemsSource="{Binding Containers}" SelectedItem="{Binding OutputContainer}"/></Grid>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Color depth"/>
                        <ComboBox Grid.Column="1" AutomationProperties.Name="Color depth" ItemsSource="{Binding ColorDepths}" SelectedItem="{Binding ColorDepth}"/></Grid>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Frame rate"/>
                        <ComboBox Grid.Column="1" AutomationProperties.Name="Frame rate mode" ItemsSource="{Binding FrameRateModes}" SelectedItem="{Binding FrameRateMode}"/></Grid>
                </StackPanel>
            </Border>

            <!-- Audio -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="head" Text="Audio"/>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Audio codec"/>
                        <ComboBox Grid.Column="1" AutomationProperties.Name="Audio codec" ItemsSource="{Binding AudioCodecs}" SelectedItem="{Binding AudioCodec}"/></Grid>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Bitrate (kbps)"/>
                        <NumericUpDown Grid.Column="1" AutomationProperties.Name="Audio bitrate in kbps" HorizontalAlignment="Right" Width="140" Minimum="64" Maximum="512"
                                       Increment="32" Value="{Binding AudioBitrateKbps}"/></Grid>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Captions"/>
                        <ComboBox Grid.Column="1" AutomationProperties.Name="Captions format" ItemsSource="{Binding CaptionFormats}" SelectedItem="{Binding CaptionsFormat}"/></Grid>
                </StackPanel>
            </Border>

            <!-- Custom cutting knobs -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="head" Text="Custom cutting"/>
                    <TextBlock Classes="lbl" FontSize="12" TextWrapping="Wrap"
                               Text="Used by the “Custom” strength. Noise floor and minimum keep apply to every clean."/>
                    <StackPanel Spacing="3">
                        <TextBlock Classes="lbl" Text="{Binding PauseThreshold, StringFormat='Cut pauses longer than {0:0.00}s'}"/>
                        <Slider Minimum="0.1" Maximum="2.0" Value="{Binding PauseThreshold}"/>
                    </StackPanel>
                    <StackPanel Spacing="3">
                        <TextBlock Classes="lbl" Text="{Binding BreathingRoom, StringFormat='Breathing room {0:0.00}s'}"/>
                        <Slider Minimum="0" Maximum="0.5" Value="{Binding BreathingRoom}"/>
                    </StackPanel>
                    <StackPanel Spacing="3">
                        <TextBlock Classes="lbl" Text="{Binding SilenceFloorDB, StringFormat='Silence below {0:0}dB'}"/>
                        <Slider Minimum="-60" Maximum="-10" Value="{Binding SilenceFloorDB}"/>
                    </StackPanel>
                    <StackPanel Spacing="3">
                        <TextBlock Classes="lbl" Text="{Binding MinKeep, StringFormat='Drop kept clips under {0:0.00}s'}"/>
                        <Slider Minimum="0" Maximum="0.5" Value="{Binding MinKeep}"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Repeated-take sensitivity"/>
                        <ComboBox Grid.Column="1" AutomationProperties.Name="Repeated-take sensitivity" ItemsSource="{Binding RetakeSensitivities}" SelectedItem="{Binding RetakeSensitivity}"/></Grid>
                </StackPanel>
            </Border>

            <!-- Speech model (filler / retake detection) -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="head" Text="Speech model"/>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Model"/>
                        <ComboBox Grid.Column="1" AutomationProperties.Name="Speech model" MinWidth="200"
                                  ItemsSource="{Binding ModelOptions}" SelectedItem="{Binding SelectedModel}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:ModelSpec">
                                    <TextBlock Text="{Binding DisplayWithSize}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox></Grid>
                    <TextBlock Classes="lbl" FontSize="12" TextWrapping="Wrap" Text="{Binding SelectedModel.Summary}"/>
                    <StackPanel Spacing="4">
                        <TextBlock Classes="lbl" FontSize="12" Text="Or use a custom whisper.cpp model (.bin):"/>
                        <TextBox AutomationProperties.Name="Custom speech model path" PlaceholderText="Path to a .bin (leave empty to use the model above)"
                                 Text="{Binding CustomModelPath}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Output / safety -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="head" Text="Output"/>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Prepare an editor timeline (FCPXML), don't render"/>
                        <ToggleSwitch Grid.Column="1" AutomationProperties.Name="Prepare an editor timeline instead of rendering"
                                      HorizontalAlignment="Right" IsChecked="{Binding ExportToEditor}"/></Grid>
                    <TextBlock Classes="lbl" FontSize="12" TextWrapping="Wrap"
                               Text="Writes a project folder with an .fcpxml timeline + a copy of your footage (no re-encode) — import it into DaVinci Resolve or another editor."/>
                    <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding !ExportToEditor}"><TextBlock Grid.Column="0" Classes="lbl" Text="Also write separate video + audio files"/>
                        <ToggleSwitch Grid.Column="1" AutomationProperties.Name="Also write separate video and audio files"
                                      HorizontalAlignment="Right" IsChecked="{Binding SplitTracks}"/></Grid>
                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding SplitTracks}" IsEnabled="{Binding !ExportToEditor}"><TextBlock Grid.Column="0" Classes="lbl" Text="Split audio format"/>
                        <ComboBox Grid.Column="1" AutomationProperties.Name="Split audio format"
                                  ItemsSource="{Binding SplitAudioFormats}" SelectedItem="{Binding SplitAudioFormat}"/></Grid>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Clean up to N files at once"/>
                        <NumericUpDown Grid.Column="1" AutomationProperties.Name="Clean up to N files at once"
                                       HorizontalAlignment="Right" Width="140" Minimum="1" Maximum="4"
                                       Increment="1" Value="{Binding MaxParallel}"/></Grid>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Keep a backup copy of each original"/>
                        <ToggleSwitch Grid.Column="1" AutomationProperties.Name="Keep a backup copy of each original"
                                      HorizontalAlignment="Right" IsChecked="{Binding BackupOriginal}"/></Grid>
                    <TextBlock Classes="lbl" FontSize="12" TextWrapping="Wrap"
                               Text="Crisp always writes a separate cleaned file and never touches the source. With this on, it also keeps an extra pristine copy in ~/.crisp/Originals before cleaning."/>
                </StackPanel>
            </Border>

            <!-- Watch folder -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="head" Text="Watch folder"/>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Auto-clean new videos in a folder"/>
                        <ToggleSwitch Grid.Column="1" AutomationProperties.Name="Watch a folder and auto-clean new videos"
                                      HorizontalAlignment="Right" IsChecked="{Binding WatchEnabled}"/></Grid>
                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding WatchEnabled}">
                        <TextBox Grid.Column="0" AutomationProperties.Name="Watch folder path"
                                 PlaceholderText="Folder to watch…" Text="{Binding WatchFolderPath}"/>
                        <Button Grid.Column="1" Content="Browse…" Click="OnPickWatchFolder" Margin="8,0,0,0"/>
                    </Grid>
                    <TextBlock Classes="lbl" FontSize="12" TextWrapping="Wrap"
                               Text="While Crisp is open, any new video dropped into this folder is queued and cleaned automatically."/>
                    <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Classes="lbl" Text="Add &quot;Clean with Crisp&quot; to the Explorer right-click menu"/>
                        <ToggleSwitch Grid.Column="1" AutomationProperties.Name="Add Clean with Crisp to the Explorer right-click menu"
                                      HorizontalAlignment="Right" IsChecked="{Binding ExplorerIntegration}"/></Grid>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Content="Reveal log files" Click="OnRevealLogs"
                        Background="Transparent" BorderThickness="0" Padding="0"
                        Foreground="{DynamicResource CrispAccent}" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="Done" Click="OnDone" Classes="accent"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Window>
