<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="using:Crisp.Services"
        xmlns:controls="using:Crisp.Views.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="520"
        x:Class="Crisp.Views.WhatsNewWindow"
        x:DataType="svc:Updater"
        Width="500" Height="520" MinWidth="420" MinHeight="360"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Title="What's New">

    <DockPanel LastChildFill="True">
        <!-- Reserve the native (Mica) caption strip so content clears it. -->
        <Panel DockPanel.Dock="Top" Height="34"/>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="24,2,24,12" VerticalAlignment="Center">
            <controls:WaveformMark Height="20" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding AvailableVersion, StringFormat='What’s New in Crisp {0}'}"
                       Classes="subtitle" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="24,12,24,20">
            <Button Content="Download" Click="OnDownload" Classes="accent"/>
            <Button Content="Close" Click="OnClose"/>
        </StackPanel>
        <Border Classes="card" Padding="14" Margin="24,0,24,0">
            <ScrollViewer>
                <SelectableTextBlock Text="{Binding Notes}" TextWrapping="Wrap"
                                     FontFamily="Cascadia Mono,Menlo,Consolas,monospace" FontSize="12"/>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
