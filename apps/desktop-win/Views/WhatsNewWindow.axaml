<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="using:Crisp.Services"
        xmlns:controls="using:Crisp.Views.Controls"
        xmlns:crisp="using:Crisp"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="540"
        x:Class="Crisp.Views.WhatsNewWindow"
        x:DataType="svc:Updater"
        Width="520" Height="540" MinWidth="420" MinHeight="360"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Title="What's New">

    <DockPanel LastChildFill="True">
        <!-- Reserve the native (Mica) caption strip so content clears it. -->
        <Panel DockPanel.Dock="Top" Height="{x:Static crisp:WindowChrome.TitleBarHeight}"/>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="24,2,24,14" VerticalAlignment="Center">
            <controls:WaveformMark Height="20" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding AvailableVersion, StringFormat='What’s New in Crisp {0}'}"
                       Classes="subtitle" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Footer command bar -->
        <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource CrispDivider}"
                BorderThickness="0,1,0,0" Padding="24,12,24,16" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="Download" Click="OnDownload" Classes="accent"/>
                <Button Content="Close" Click="OnClose"/>
            </StackPanel>
        </Border>

        <Border Classes="card" Padding="14" Margin="24,0,24,0">
            <ScrollViewer>
                <SelectableTextBlock Text="{Binding Notes}" TextWrapping="Wrap"
                                     FontFamily="Cascadia Mono,Menlo,Consolas,monospace" FontSize="12"/>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
