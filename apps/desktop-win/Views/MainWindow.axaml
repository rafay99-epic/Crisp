<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Crisp.ViewModels"
        xmlns:controls="using:Crisp.Views.Controls"
        xmlns:pages="using:Crisp.Views.Pages"
        xmlns:views="using:Crisp.Views"
        xmlns:crisp="using:Crisp"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="660"
        x:Class="Crisp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="980" Height="660" MinWidth="760" MinHeight="540"
        Background="Transparent"
        Title="Crisp">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid RowDefinitions="Auto,*">

            <!-- Reserve the native (Mica) caption strip — the system draws the window
                 title and caption buttons there and owns its input. -->
            <Panel Grid.Row="0" Height="{x:Static crisp:WindowChrome.TitleBarHeight}"/>

            <!-- NavigationView: pane on Mica, page content on the rounded layer. -->
            <Grid Grid.Row="1" ColumnDefinitions="Auto,*">

                <!-- Navigation pane -->
                <DockPanel Grid.Column="0" Width="{DynamicResource CrispNavWidth}"
                           Margin="4,6,4,4" LastChildFill="False">
                    <StackPanel DockPanel.Dock="Top" Spacing="2">
                        <controls:NavItem x:Name="NavHome" GroupName="Nav" Glyph="&#xE80F;" Content="Home"
                                          IsChecked="True" IsCheckedChanged="OnNavChanged"/>
                        <controls:NavItem x:Name="NavHistory" GroupName="Nav" Glyph="&#xE81C;" Content="History"
                                          IsCheckedChanged="OnNavChanged"/>
                    </StackPanel>
                    <controls:NavItem DockPanel.Dock="Bottom" x:Name="NavSettings" GroupName="Nav"
                                      Glyph="&#xE713;" Content="Settings"
                                      IsCheckedChanged="OnNavChanged"/>
                </DockPanel>

                <!-- Page host -->
                <Border Grid.Column="1" Classes="contentPane">
                    <Panel>
                        <pages:HomePage x:Name="PageHome"/>
                        <pages:HistoryPage x:Name="PageHistory" DataContext="{Binding History}" IsVisible="False"/>
                        <pages:SettingsPage x:Name="PageSettings" DataContext="{Binding Settings}" IsVisible="False"/>
                    </Panel>
                </Border>
            </Grid>
        </Grid>

        <!-- Onboarding tour — owns the window on first launch until finished (the
             model step gates completion, mirroring macOS). -->
        <Border IsVisible="{Binding Onboarding.IsPresented}" Background="{DynamicResource CrispWindowBg}">
            <Grid RowDefinitions="Auto,*">
                <Panel Grid.Row="0" Height="{x:Static crisp:WindowChrome.TitleBarHeight}"/>
                <views:OnboardingView Grid.Row="1"/>
            </Grid>
        </Border>
    </Grid>
</Window>
