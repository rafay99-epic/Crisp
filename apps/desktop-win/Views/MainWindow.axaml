<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Crisp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="520"
        x:Class="Crisp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="640" Height="520"
        Title="Crisp">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel Margin="20" LastChildFill="True">

        <TextBlock DockPanel.Dock="Top" Text="Crisp — engine pipe proof"
                   FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <TextBox Grid.Column="0" PlaceholderText="Path to a video file…"
                     Text="{Binding VideoPath}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Browse…" Margin="8,0,0,0"
                    Click="OnBrowse" IsEnabled="{Binding !IsRunning}"/>
        </Grid>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="Clean" Command="{Binding CleanCommand}"
                    IsEnabled="{Binding !IsRunning}" Classes="accent"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}"
                    IsEnabled="{Binding IsRunning}"/>
        </StackPanel>

        <ProgressBar DockPanel.Dock="Top" Minimum="0" Maximum="100"
                     Value="{Binding Progress}" Height="6" Margin="0,0,0,6"/>
        <TextBlock DockPanel.Dock="Top" Text="{Binding Status}"
                   Foreground="Gray" Margin="0,0,0,10"/>

        <Border BorderBrush="#33000000" BorderThickness="1" CornerRadius="6">
            <ListBox ItemsSource="{Binding Log}" FontFamily="monospace" FontSize="12"/>
        </Border>

    </DockPanel>
</Window>
