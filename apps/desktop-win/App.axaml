<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Crisp.App"
             xmlns:local="using:Crisp"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows the system light/dark setting. -->

    <!-- System tray presence (port of the macOS menu-bar item) -->
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/AppIcon.ico" ToolTipText="Crisp" Clicked="OnTrayClicked">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Open Crisp" Click="OnTrayOpen"/>
                        <NativeMenuItem Header="Quit Crisp" Click="OnTrayQuit"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Theme/Tokens.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="/Theme/Styles.axaml"/>
    </Application.Styles>
</Application>
